# ============================================
# Config-repo variables de ejemplo
# Copia a .env y rellena con tus valores reales
# ============================================

# PostgreSQL
AUTH_DB_USER=admin
AUTH_DB_PASSWORD=1234

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=1234

# Auth defaults (solo desarrollo)
ADMIN_PASSWORD=admin123
USER_PASSWORD=user123
CLIENT_SECRET=secret
IDENTITY_CLIENT_SECRET=identity-secret

# Google OAuth2 (opcional, vacío si no se usa)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spring
SPRING_PROFILES_ACTIVE=dev
